{
  "name": "proyecto-e2e-opencart",
  "version": "1.0.0",
  "description": "Proyecto de automatización E2E + API Testing con Cypress para OpenCart",
  "main": "index.js",
  "scripts": {
  "cypress:open": "cypress open",
  "clean:reports": "npx rimraf reports",
  "pretest:run": "npm run clean:reports",
  "test:run": "cypress run",
  "posttest:run": "npm run report:merge && npm run report:generate",
  "report:merge": "npx mochawesome-merge reports/mochawesome/*.json > reports/full-report.json",
  "report:generate": "npx marge reports/full-report.json -f index -o reports/final-html"
  },
  "keywords": [
    "cypress",
    "e2e",
    "automation",
    "opencart"
  ],
  "author": "Eduardo Parra",
  "license": "ISC",
  "dependencies": {
    "cypress": "^15.13.0"
  },
  "devDependencies": {
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^5.0.0"
  }
}